  "description": "Shared standard for the Line-Up FE",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin"
  ],
  "author": "Line-Up",
  "main": "./lib/index.js",
  "exports": "./lib/index.js",
  "scripts": {
