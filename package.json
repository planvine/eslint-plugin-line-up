    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "requireindex": "^1.2.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-doc-generator": "^3.3.1",
    "eslint-plugin-eslint-plugin": "^5.0.0",
    "eslint-plugin-node": "^11.1.0",
    "mocha": "^11.0.0",
    "npm-run-all2": "^8.0.0",
    "prettier": "^3.4.0",
